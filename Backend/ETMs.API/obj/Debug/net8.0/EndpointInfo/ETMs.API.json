            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.DTOs.CreateEmployeeDTO": {
        "required": [
          "department",
          "email",
          "name",
          "password",
          "role"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "role": {
            "minLength": 1,
            "type": "string"
          },
          "department": {
            "minLength": 1,
            "type": "string"
          },
          "managerId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.DTOs.ExpenseItemDTO": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "nullable": true
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "fileIndex": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.DTOs.ItineraryDTO": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "type": "string",
            "nullable": true
          },
          "activityDetails": {
            "type": "string",
            "nullable": true
          },
          "hotelOrAccommodation": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.DTOs.LoginRequestDTO": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.DTOs.ReimbursementApprovalDTO": {
        "type": "object",
        "properties": {
          "expenseId": {
            "type": "integer",
            "format": "int32"
          },
          "approvedAmount": {
            "type": "number",
            "format": "double"
          },
          "managerNotes": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "$ref": "#/components/schemas/ETMs.Models.Enums.ReimbursementStatus"
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.DTOs.SetBudgetDTO": {
        "required": [
          "budgetLimit",
          "departmentName"
        ],
        "type": "object",
        "properties": {
          "departmentName": {
            "minLength": 1,
            "type": "string"
          },
          "budgetLimit": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.DTOs.TravelRequestCreateDTO": {
        "required": [
          "destination",
          "endDate",
          "estimatedBudget",
          "fromLocation",
          "purpose",
          "startDate"
        ],
        "type": "object",
        "properties": {
          "fromLocation": {
            "minLength": 1,
            "type": "string"
          },
          "destination": {
            "minLength": 1,
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "purpose": {
            "minLength": 1,
            "type": "string"
          },
          "estimatedBudget": {
            "maximum": 100000,
            "minimum": 1,
            "type": "number",
            "format": "double"
          },
          "itineraries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ETMs.Models.DTOs.ItineraryDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.DTOs.UpdateEmployeeDTO": {
        "required": [
          "department",
          "email",
          "name",
          "role"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "role": {
            "minLength": 1,
            "type": "string"
          },
          "department": {
            "minLength": 1,
            "type": "string"
          },
          "managerId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ETMs.Models.Enums.ReimbursementStatus": {
        "enum": [
          1,
          2,
          3,
          4
        ],
        "type": "integer",
        "format": "int32"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "JWT Authorization header using the Bearer scheme. Example: \"Bearer {token}\"",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
